# Environment Configuration Template
# คัดลอกไฟล์นี้เป็น .env.development หรือ .env.production
# แล้วแก้ไขค่าตามสภาพแวดล้อมของคุณ

# Base URL สำหรับ Vue App
VUE_APP_BASE_URL=/

# API Base URL
VUE_APP_API_BASE_URL=/intsys/rao/rao_backend/api

# Backend Port (for proxy in development)
VUE_APP_BACKEND_PORT=8080

# Environment Mode
NODE_ENV=development
