# Development Environment Configuration
# ไฟล์นี้ใช้สำหรับ Development Mode (npm run serve)

# Base URL สำหรับ Vue App
VUE_APP_BASE_URL=/

# API Base URL (ใช้ relative path เพื่อให้ proxy ทำงาน)
VUE_APP_API_BASE_URL=/intsys/rao/rao_backend/api

# Backend Port (MAMP)
VUE_APP_BACKEND_PORT=8080

# Environment Mode
NODE_ENV=development
